generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Invoice {
  id           String   @id @default(cuid())

  type         String
  customNumber String?
  sequence     Int
  month        Int
  year         Int

  isProforma   Boolean  @default(false)

  clientData   Json
  serviceData  Json
  items        Json

  totalHT      Float
  totalTVA     Float
  totalTTC     Float

  signatureName  String?
  signatureImage String?

  createdAt    DateTime @default(now())
}

model InvoiceCounter {
  id     String @id @default(cuid())

  type   String
  month  Int
  year   Int
  count  Int

  @@unique([type, month, year], name: "type_month_year")
}